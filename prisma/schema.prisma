generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Profile {
  id          String   @id @default(cuid())
  name        String
  avatarColor String   @default("#3b82f6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  incomes   Income[]
  expenses  Expense[]
  debts     Debt[]
  assets    Asset[]
  goals     Goal[]
  scenarios Scenario[]
  checkins  MonthlyCheckin[]
}

model Income {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  frequency String   @default("monthly")
  taxRate   Float    @default(0)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  amount    Float
  frequency String   @default("monthly")
  category  String   @default("other")
  isFixed   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Debt {
  id              String   @id @default(cuid())
  profileId       String
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name            String
  balance         Float
  interestRate    Float
  minimumPayment  Float
  type            String   @default("personal")
  originalLoan    Float?   // Original loan amount (optional)
  loanTermMonths  Int?     // Loan term in months (optional)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Asset {
  id                  String   @id @default(cuid())
  profileId           String
  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name                String
  value               Float
  type                String   @default("other")
  growthRate          Float    @default(0)
  monthlyContribution Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Goal {
  id            String   @id @default(cuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name          String
  targetAmount  Float
  currentAmount Float    @default(0)
  targetDate    DateTime
  priority      Int      @default(1)
  type          String   @default("custom")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Scenario {
  id          String           @id @default(cuid())
  profileId   String
  profile     Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String           @default("")
  isBaseline    Boolean          @default(false)
  snapshotData  String?          // JSON blob of full FinancialState for sandbox mode
  changes       ScenarioChange[]
  createdAt     DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ScenarioChange {
  id         String   @id @default(cuid())
  scenarioId String
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  field      String
  oldValue   String
  newValue   String
  createdAt  DateTime @default(now())
}

model MonthlyCheckin {
  id                 String        @id @default(cuid())
  profileId          String
  profile            Profile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  month              Int
  year               Int
  totalIncome        Float
  totalExpenses      Float
  expensesByCategory String        // JSON: { housing: 1200, food: 450, ... }
  netWorth           Float?
  overallGrade       String        // A, B, C, D, F
  gradeDetails       String        // JSON: { housing: { budgeted: 1500, actual: 1200, grade: "A" }, ... }
  aiSuggestions      String?       // JSON from Claude response
  transactions       Transaction[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([profileId, month, year])
}

model Transaction {
  id          String         @id @default(cuid())
  checkinId   String
  checkin     MonthlyCheckin @relation(fields: [checkinId], references: [id], onDelete: Cascade)
  date        DateTime
  description String
  amount      Float
  isIncome    Boolean        @default(false)
  category    String         @default("other")
  source      String
  excluded    Boolean        @default(false)
  createdAt   DateTime       @default(now())
}
